    "test:font-policy": "node ../../scripts/verify-font-license-policy.mjs",
    "test:font-policy:release": "node ../../scripts/verify-font-license-policy.mjs --require-files",
    "test:visual-baselines": "node ../../scripts/test_frontend_visual_baselines.mjs",
