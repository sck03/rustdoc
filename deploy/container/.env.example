POSTGRES_DB=exportdoc
POSTGRES_USER=exportdoc
POSTGRES_PASSWORD=replace-with-a-long-random-password
EXPORTDOCMANAGER_BOOTSTRAP_TOKEN=replace-with-a-different-random-token-at-least-24-characters
# 可选：32 字节主密钥的 Base64 或 64 位十六进制；设置后必须长期安全备份，不能随意更换。
# EXPORTDOCMANAGER_MASTER_KEY=
EXPORTDOCMANAGER_WEB_PORT=8080
EXPORTDOCMANAGER_RUNTIME_ROOT=./runtime
EXPORTDOCMANAGER_ALLOWED_ORIGINS=
# Nginx 使用固定容器地址，API 只信任该地址提供的 X-Forwarded-* 请求头。
# 如果该网段与现有 Docker/VPN 网络冲突，请同时修改下面两项并保持代理地址属于该网段。
EXPORTDOCMANAGER_CONTAINER_SUBNET=172.30.238.0/24
EXPORTDOCMANAGER_REVERSE_PROXY_IP=172.30.238.10
# 若公网 HTTPS/CDN 代理位于内置 Nginx 前方，填写其直接连接来源 IP；多个地址用分号分隔。
EXPORTDOCMANAGER_ADDITIONAL_TRUSTED_PROXIES=
EXPORTDOCMANAGER_IMAGE_NAMESPACE=ghcr.io/your-github-account
EXPORTDOCMANAGER_IMAGE_TAG=latest
TZ=Asia/Shanghai
