    "test:authentication-failure-events": "node ../../scripts/test_authentication_failure_events.mjs",
    "test:session-expiry-model": "node ../../scripts/test_session_expiry_model.mjs",
    "test:service-availability-model": "node ../../scripts/test_service_availability_model.mjs",
