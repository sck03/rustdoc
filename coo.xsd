<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns="http://www.w3.org/2000/09/xmldsig#" targetNamespace="http://www.w3.org/2000/09/xmldsig#" elementFormDefault="qualified" attributeFormDefault="unqualified">
	<xs:element name="Certificate">
		<xs:annotation>
			<xs:documentation>原产地证书</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:sequence>
				<xs:element name="CertificateHead">
					<xs:annotation>
						<xs:documentation>原产地证书表头</xs:documentation>
					</xs:annotation>
					<xs:complexType>
						<xs:sequence>
							<xs:element name="CertNo">
								<xs:annotation>
									<xs:documentation>原产地证编号
                                        （证书类型+2位年份+组织机构代码+四位流水号）</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="xs:string">
										<xs:maxLength value="20"/>
									</xs:restriction>
								</xs:simpleType>
							</xs:element>
							<xs:element name="ApplyType">
								<xs:annotation>
									<xs:documentation>申请类型
                                        0：暂存
                                        1：申报</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="xs:string">
										<xs:maxLength value="1"/>
									</xs:restriction>
								</xs:simpleType>
							</xs:element>
							<xs:element name="CertStatus">
								<xs:annotation>
									<xs:documentation>证书状态
                                        0：新证
                                        1：更改证
                                        2：重发证</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="xs:string">
										<xs:maxLength value="1"/>
									</xs:restriction>
								</xs:simpleType>
							</xs:element>
							<xs:element name="CertType">
								<xs:annotation>
									<xs:documentation>原产地证书类型
                                        （C：一般产地证
                                        B:亚太证书
                                        G：普惠证书
                                        E：东盟证书
                                        F：智利证书
                                        M：欧盟蘑菇证书
                                        P：中巴证书
                                        T：烟草证书
                                        N：新西兰证书
                                        X：新加坡证书
                                        R：秘鲁
                                        H：海峡
                                        L：哥斯达黎加
                                        I：冰岛
                                        S：瑞士
                                        PR：加工装配证书
                                        TR：转口证书
                                        A：澳大利亚
                                        K：中韩
                                        AD：输往墨西哥瓷砖价格承诺原产地证书
                                        AP：输往巴基斯坦瓷砖价格承诺原产地证书
                                        GE：格鲁吉亚

CA:中柬证书

RC: RCEP证书
                                        ）</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="xs:string">
										<xs:maxLength value="2"/>
									</xs:restriction>
								</xs:simpleType>
							</xs:element>
							<xs:element name="EntMgrNo">
								<xs:annotation>
									<xs:documentation>货主企业备案号</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="xs:string">
										<xs:maxLength value="19"/>
									</xs:restriction>
								</xs:simpleType>
							</xs:element>
							<xs:element name="CiqRegNo">
								<xs:annotation>
									<xs:documentation>出口商代码</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="xs:string">
										<xs:maxLength value="18"/>
									</xs:restriction>
								</xs:simpleType>
							</xs:element>
							<xs:element name="AplRegNo">
								<xs:annotation>
									<xs:documentation>录入企业代码</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="xs:string">
										<xs:maxLength value="18"/>
									</xs:restriction>
								</xs:simpleType>
							</xs:element>
							<xs:element name="EtpsName">
								<xs:annotation>
									<xs:documentation>企业名称（中文）</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="xs:string">
										<xs:maxLength value="400"/>
									</xs:restriction>
								</xs:simpleType>
							</xs:element>
							<xs:element name="ApplName" minOccurs="0">
								<xs:annotation>
									<xs:documentation>申报员姓名
                                        （申报为必填项）</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="xs:string">
										<xs:maxLength value="20"/>
									</xs:restriction>
								</xs:simpleType>
							</xs:element>
							<xs:element name="Applicant" minOccurs="0">
								<xs:annotation>
									<xs:documentation>申报员ID，申报员身份证号
                                        （申报为必填项）</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="xs:string">
										<xs:maxLength value="18"/>
									</xs:restriction>
								</xs:simpleType>
							</xs:element>
							<xs:element name="ApplTel" minOccurs="0">
								<xs:annotation>
									<xs:documentation>申报员联系电话</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="xs:string">
										<xs:maxLength value="30"/>
									</xs:restriction>
								</xs:simpleType>
							</xs:element>
							<xs:element name="OrgCode" minOccurs="0">
								<xs:annotation>
									<xs:documentation>签证机构代码</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="xs:string">
										<xs:maxLength value="20"/>
									</xs:restriction>
								</xs:simpleType>
							</xs:element>
							<xs:element name="FetchPlace" minOccurs="0">
								<xs:annotation>
									<xs:documentation>领证机构
                                        （申报为必填项）</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="xs:string">
										<xs:maxLength value="20"/>
									</xs:restriction>
								</xs:simpleType>
							</xs:element>
							<xs:element name="AplAdd" minOccurs="0">
								<xs:annotation>
									<xs:documentation>申请地址</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="xs:string">
										<xs:maxLength value="30"/>
									</xs:restriction>
								</xs:simpleType>
							</xs:element>
							<xs:element name="InvDate" minOccurs="0">
								<xs:annotation>
									<xs:documentation>发票日期
                                        “YYYY-MM-DD”
                                        （申报为必填项）</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="xs:string">
										<xs:maxLength value="10"/>
									</xs:restriction>
								</xs:simpleType>
							</xs:element>
							<xs:element name="InvNo" minOccurs="0">
								<xs:annotation>
									<xs:documentation>发票号
                                        （申报为必填项）</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="xs:string">
										<xs:maxLength value="50"/>
									</xs:restriction>
								</xs:simpleType>
							</xs:element>
							<xs:element name="AplDate" minOccurs="0">
								<xs:annotation>
									<xs:documentation>申请日期
                                        “YYYY-MM-DD”
                                        （申报为必填项）</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="xs:string">
										<xs:maxLength value="10"/>
									</xs:restriction>
								</xs:simpleType>
							</xs:element>
							<xs:element name="DestCountry" minOccurs="0">
								<xs:annotation>
									<xs:documentation>目的国
                                        （申报为必填项）</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="xs:string">
										<xs:maxLength value="80"/>
									</xs:restriction>
								</xs:simpleType>
							</xs:element>
							<xs:element name="DestCountryCode" minOccurs="0">
								<xs:annotation>
									<xs:documentation>目的国家/地区编码</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="xs:string">
										<xs:maxLength value="4"/>
									</xs:restriction>
								</xs:simpleType>
							</xs:element>
							<xs:element name="DestCountryName" minOccurs="0">
								<xs:annotation>
									<xs:documentation>目的国家/地区名称</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="xs:string">
										<xs:maxLength value="50"/>
									</xs:restriction>
								</xs:simpleType>
							</xs:element>
							<xs:element name="Exporter" minOccurs="0">
								<xs:annotation>
									<xs:documentation>出口商
                                        （申报为必填项）</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="xs:string">
										<xs:maxLength value="400"/>
									</xs:restriction>
								</xs:simpleType>
							</xs:element>
							<xs:element name="Consignee" minOccurs="0">
								<xs:annotation>
									<xs:documentation>进口商
                                        （申报为必填项）</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="xs:string">
										<xs:maxLength value="400"/>
									</xs:restriction>
								</xs:simpleType>
							</xs:element>
							<xs:element name="GoodsSpecClause" minOccurs="0">
								<xs:annotation>
									<xs:documentation>特殊条款（商品描述）</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="xs:string">
										<xs:maxLength value="2000"/>
									</xs:restriction>
								</xs:simpleType>
							</xs:element>
							<xs:element name="Mark" minOccurs="0">
								<xs:annotation>
									<xs:documentation>唛头
                                        （申报为必填项）</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="xs:string">
										<xs:maxLength value="2000"/>
									</xs:restriction>
								</xs:simpleType>
							</xs:element>
							<xs:element name="LoadPort" minOccurs="0">
								<xs:annotation>
									<xs:documentation>启运港</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="xs:string">
										<xs:maxLength value="50"/>
									</xs:restriction>
								</xs:simpleType>
							</xs:element>
							<xs:element name="UnloadPort" minOccurs="0">
								<xs:annotation>
									<xs:documentation>卸货港</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="xs:string">
										<xs:maxLength value="50"/>
									</xs:restriction>
								</xs:simpleType>
							</xs:element>
							<xs:element name="TransMeans" minOccurs="0">
								<xs:annotation>
									<xs:documentation>运输方式（运输工具）</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="xs:string">
										<xs:maxLength value="100"/>
									</xs:restriction>
								</xs:simpleType>
							</xs:element>
							<xs:element name="TransName" minOccurs="0">
								<xs:annotation>
									<xs:documentation>运输工具船名/航次</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="xs:string">
										<xs:maxLength value="100"/>
									</xs:restriction>
								</xs:simpleType>
							</xs:element>
							<xs:element name="TransCountryCode" minOccurs="0">
								<xs:annotation>
									<xs:documentation>中转国/地区编码</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="xs:string">
										<xs:maxLength value="4"/>
									</xs:restriction>
								</xs:simpleType>
							</xs:element>
							<xs:element name="TransCountryName" minOccurs="0">
								<xs:annotation>
									<xs:documentation>中转国/地区名称</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="xs:string">
										<xs:maxLength value="150"/>
									</xs:restriction>
								</xs:simpleType>
							</xs:element>
							<xs:element name="TransPort" minOccurs="0">
								<xs:annotation>
									<xs:documentation>转运港</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="xs:string">
										<xs:maxLength value="50"/>
									</xs:restriction>
								</xs:simpleType>
							</xs:element>
							<xs:element name="DestPort" minOccurs="0">
								<xs:annotation>
									<xs:documentation>目的港</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="xs:string">
										<xs:maxLength value="50"/>
									</xs:restriction>
								</xs:simpleType>
							</xs:element>
							<xs:element name="TransDetails" minOccurs="0">
								<xs:annotation>
									<xs:documentation>运输细节</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="xs:string">
										<xs:maxLength value="630"/>
									</xs:restriction>
								</xs:simpleType>
							</xs:element>
							<xs:element name="IntendExpDate" minOccurs="0">
								<xs:annotation>
									<xs:documentation>出运日期
                                        “YYYY-MM-DD”
                                        （申报为必填项）</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="xs:string">
										<xs:maxLength value="10"/>
									</xs:restriction>
								</xs:simpleType>
							</xs:element>
							<xs:element name="TradeModeCode" minOccurs="0">
								<xs:annotation>
									<xs:documentation>贸易方式代码</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="xs:string">
										<xs:maxLength value="4"/>
									</xs:restriction>
								</xs:simpleType>
							</xs:element>
							<xs:element name="FOBValue" minOccurs="0">
								<xs:annotation>
									<xs:documentation>FOB值</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="xs:string">
										<xs:maxLength value="25"/>
									</xs:restriction>
								</xs:simpleType>
							</xs:element>
							<xs:element name="TotalAmt" minOccurs="0">
								<xs:annotation>
									<xs:documentation>总金额</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="xs:string">
										<xs:maxLength value="25"/>
									</xs:restriction>
								</xs:simpleType>
							</xs:element>
							<xs:element name="Note" minOccurs="0">
								<xs:annotation>
									<xs:documentation>申请书备注</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="xs:string">
										<xs:maxLength value="1000"/>
									</xs:restriction>
								</xs:simpleType>
							</xs:element>
							<xs:element name="ContractNo" minOccurs="0">
								<xs:annotation>
									<xs:documentation>合同号</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="xs:string">
										<xs:maxLength value="200"/>
									</xs:restriction>
								</xs:simpleType>
							</xs:element>
							<xs:element name="LcNo" minOccurs="0">
								<xs:annotation>
									<xs:documentation>信用证号</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="xs:string">
										<xs:maxLength value="50"/>
									</xs:restriction>
								</xs:simpleType>
							</xs:element>
							<xs:element name="SpecInvTerms" minOccurs="0">
								<xs:annotation>
									<xs:documentation>发票特殊条款</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="xs:string">
										<xs:maxLength value="1000"/>
									</xs:restriction>
								</xs:simpleType>
							</xs:element>
							<xs:element name="PriceTerms" minOccurs="0">
								<xs:annotation>
									<xs:documentation>价格条款</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="xs:string">
										<xs:maxLength value="20"/>
									</xs:restriction>
								</xs:simpleType>
							</xs:element>
							<xs:element name="Curr" minOccurs="0">
								<xs:annotation>
									<xs:documentation>货币单位
                                        （申报为必填项
                                        常用单位：
                                        CNY：人民币、
                                        USD：美元
                                        EUR：欧元
                                        HKD：港币
                                        GBP：英镑
                                        JPY：日元
                                        KRW：韩元
                                        CAD：加元
                                        AUD：澳元
                                        CHF：瑞郎
                                        SGD：新加坡元
                                        ）</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="xs:string">
										<xs:maxLength value="10"/>
									</xs:restriction>
								</xs:simpleType>
							</xs:element>
							<xs:element name="Remark" minOccurs="0">
								<xs:annotation>
									<xs:documentation>证书备注信息</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="xs:string">
										<xs:maxLength value="300"/>
									</xs:restriction>
								</xs:simpleType>
							</xs:element>
							<xs:element name="ProducerSertFlag" minOccurs="0">
								<xs:annotation>
									<xs:documentation>是否生产商保密</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="xs:string">
										<xs:maxLength value="1"/>
									</xs:restriction>
								</xs:simpleType>
							</xs:element>
							<xs:element name="ExhibitFlag" minOccurs="0">
								<xs:annotation>
									<xs:documentation>是否展览证书
                                        0：非展览
                                        1：展览</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="xs:string">
										<xs:maxLength value="1"/>
									</xs:restriction>
								</xs:simpleType>
							</xs:element>
							<xs:element name="ThirdPartyInvFlag" minOccurs="0">
								<xs:annotation>
									<xs:documentation>是否第三方发票，第三方发票标志
                                        0：非第三方
                                        1：第三方</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="xs:string">
										<xs:maxLength value="1"/>
									</xs:restriction>
								</xs:simpleType>
							</xs:element>
							<xs:element name="ExporterTel" minOccurs="0">
								<xs:annotation>
									<xs:documentation>出口商电话
                                        （申报为必填项）</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="xs:string">
										<xs:maxLength value="50"/>
									</xs:restriction>
								</xs:simpleType>
							</xs:element>
							<xs:element name="ExporterFax" minOccurs="0">
								<xs:annotation>
									<xs:documentation>出口商传真
                                        （申报为必填项）</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="xs:string">
										<xs:maxLength value="50"/>
									</xs:restriction>
								</xs:simpleType>
							</xs:element>
							<xs:element name="ExporterEmail" minOccurs="0">
								<xs:annotation>
									<xs:documentation>出口商邮箱
                                        （申报为必填项）</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="xs:string">
										<xs:maxLength value="50"/>
									</xs:restriction>
								</xs:simpleType>
							</xs:element>
							<xs:element name="ConsigneeTel" minOccurs="0">
								<xs:annotation>
									<xs:documentation>进口商电话</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="xs:string">
										<xs:maxLength value="50"/>
									</xs:restriction>
								</xs:simpleType>
							</xs:element>
							<xs:element name="ConsigneeFax" minOccurs="0">
								<xs:annotation>
									<xs:documentation>进口商传真</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="xs:string">
										<xs:maxLength value="50"/>
									</xs:restriction>
								</xs:simpleType>
							</xs:element>
							<xs:element name="ConsigneeEmail" minOccurs="0">
								<xs:annotation>
									<xs:documentation>进口商邮箱</xs:documentation>
								</xs:annotation>
								<xs:simpleType>
									<xs:restriction base="xs:string">
										<xs:maxLength value="50"/>
									</xs:restriction>
								</xs:simpleType>
